{
  "name": "FarmData2 Development Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "TZ": "America/New_York"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/fd2dev/FarmData2,type=bind",
  "workspaceFolder": "/home/fd2dev/FarmData2",
  "remoteUser": "fd2dev",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "noPassword",
      "webPort": "6901",
      "vncPort": "5901"
    },
    "ghcr.io/devcontainers-extra/features/shfmt:1": {},
    "ghcr.io/devcontainers-extra/features/shellcheck:1": {},
    "ghcr.io/shinepukur/devcontainer-features/vale:1": {
      "version": "3.9.6"
    }
  }
}
